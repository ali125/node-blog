<%- include('../layouts/header') %>
<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Posts</h4>
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                    <tr>
                        <th> Image </th>
                        <th> Title </th>
                        <th> Content </th>
                        <th> Progress </th>
                        <th></th>
                    </tr>
                    </thead>
                    <tbody>
                    <% if(data.length > 0) { %>
                        <% data.forEach(item => { %>
                            <tr>
                                <td class="py-1">
                                    <img src="<%= item.imageUrl %>" alt="image" />
                                </td>
                                <td> <%= item.title %> </td>
                                <td> <%= item.content %> </td>
                                <td>
                                    <div class="progress">
                                        <div class="progress-bar bg-success" role="progressbar" style="width: 25%" aria-valuenow="25" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                </td>
                                <td>
                                    <a href="/admin/posts/<%= item._id %>/edit" class="btn btn-sm btn-warning btn-outline">Edit</a>
                                    <a href="/admin/posts/<%= item._id %>/delete" class="btn btn-sm btn-danger btn-outline">Delete</a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
<%- include('../layouts/footer') %>
