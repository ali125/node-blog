<%- include('../layouts/header') %>
<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Posts</h4>
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                    <tr>
                        <th> Title </th>
                        <th> User Name </th>
                        <th> Content </th>
                        <th> Date </th>
                        <th></th>
                    </tr>
                    </thead>
                    <tbody>
                    <% if(data.length > 0) { %>
                        <% data.forEach(item => { %>
                            <tr>
                                <td> <%= item.title %> </td>
                                <td> <%= item.name %> </td>
                                <td> <%= item.short_content %> </td>
                                <td><%= formatDate(item.createdAt) %></td>
                                <td>
                                    <a href="/admin/messages/<%= item._id %>" class="btn btn-sm btn-info btn-outline">Watch</a>
                                    <a href="/admin/messages/<%= item._id %>/delete" class="btn btn-sm btn-danger btn-outline">Delete</a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
<%- include('../layouts/footer') %>
